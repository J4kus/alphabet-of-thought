{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "alphabet of thought",
    "fileTypes": ["json"],
	"patterns": [
		{
            "name": "constant.character.concept",
            "match": "[A-Z][^(:\"'`]*(?=[(:\"'`]|$)"
        },
        {
            "name": "variable.parameter.attribute.aot",
            "match": "\\b[a-z]\\w*\\b"
        },
        {
            "name": "string.quoted.double.value.aot",
            "match": ":.*$"
        },
        {
            "name": "keyword.control.example.aot",
            "match": "-.*$"
        },
        {
            "name": "constant.numeric.alias.aot", 
            "match": "\\([^)]*\\)"
        },
        {
            "name": "support.type.literal.aot",
            "match": "`[^`]*`"
        },
        {
            "name": "comment.line.map.aot",
            "match": "\\.{3}.*$"
        },
        {
            "name": "invalid.deprecated.aot",
            "match": "~.*"
        },
        {
            "name": "support.type.table.aot", 
            "match": "\\|.*$"
        }
        
	],
	"scopeName": "source.aot"
}